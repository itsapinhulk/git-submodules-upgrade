#!/usr/bin/env bash
# Package release artifacts (action.yml + the scripts the action runs) into a zip.
# Usage: scripts/package <output-dir>
set -euo pipefail

if [[ $# -ne 1 ]]; then
    echo "Usage: scripts/package <output-dir>" >&2
    exit 1
fi

OUTPUT_DIR="$(realpath -m "$1")"
REPO_ROOT="$(git rev-parse --show-toplevel)"

# Scripts that action.yml invokes at runtime.
RUNTIME_SCRIPTS=(upgrade-git-submodules run-upgrade open-pr)

for s in "${RUNTIME_SCRIPTS[@]}"; do
    if [[ ! -f "$REPO_ROOT/scripts/$s" ]]; then
        echo "Error: scripts/$s not found — run scripts/vendor-upgrade-script and retry." >&2
        exit 1
    fi
done

mkdir -p "$OUTPUT_DIR"

STAGING=$(mktemp -d)
trap 'rm -rf "$STAGING"' EXIT

cp "$REPO_ROOT/action.yml" "$STAGING/"
mkdir -p "$STAGING/scripts"
for s in "${RUNTIME_SCRIPTS[@]}"; do
    cp "$REPO_ROOT/scripts/$s" "$STAGING/scripts/"
done

ZIP="$OUTPUT_DIR/release.zip"
(cd "$STAGING" && zip -r "$ZIP" .)

echo "Packaged: $ZIP"
