#!/usr/bin/env bash
# Bump the version in the VERSION file and commit the change.
# Usage: scripts/bump-version [major|patch]
# Defaults to patch if no argument is given.
set -euo pipefail

COMPONENT="${1:-patch}"

if [[ "$COMPONENT" != "major" && "$COMPONENT" != "patch" ]]; then
    echo "Usage: scripts/bump-version [major|patch]" >&2
    exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
VERSION_FILE="$REPO_ROOT/VERSION"

if [[ ! -f "$VERSION_FILE" ]]; then
    echo "Error: VERSION file not found at $VERSION_FILE" >&2
    exit 1
fi

CURRENT="$(cat "$VERSION_FILE" | tr -d '[:space:]')"

if ! [[ "$CURRENT" =~ ^v([0-9]+)\.([0-9]+)$ ]]; then
    echo "Error: VERSION file contains invalid version '$CURRENT' (expected vMAJOR.PATCH)" >&2
    exit 1
fi

MAJOR="${BASH_REMATCH[1]}"
PATCH="${BASH_REMATCH[2]}"

if [[ "$COMPONENT" == "major" ]]; then
    MAJOR=$((MAJOR + 1))
    PATCH=0
else
    PATCH=$((PATCH + 1))
fi

NEW="v${MAJOR}.${PATCH}"
echo "$NEW" > "$VERSION_FILE"

echo "Bumped $CURRENT → $NEW"
